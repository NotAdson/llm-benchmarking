{
  "output_dir": "results",
  "cache_dir": "model_cache",
  "log_level": "INFO",
  "seed": 42,
  "huggingface": {
    "token_path": ".hf_token",
    "use_auth": true
  },
  "models": {
    "gemma": {
      "gemma-3-1b-lora": {
        "type": "gemma",
        "name": "google/gemma-3-1b-it",
        "peft_model": "adson-silva/gemma3-1b-gsm8k",
        "torch_dtype": "float16",
        "low_memory": false,
        "requires_auth": false
      },
      "gemma-3-1b-it": {
        "type": "gemma",
        "name": "google/gemma-3-1b-it",
        "torch_dtype": "float16",
        "low_memory": false,
        "requires_auth": false
      },
      "gemma-3-4b-lora": {
        "type": "gemma",
        "name": "google/gemma-3-4b-it",
        "peft_model": "adson-silva/gemma3-4b-gsm8k",
        "torch_dtype": "float16",
        "low_memory": true,
        "requires_auth": false
      },
      "gemma-3-4b-it": {
        "type": "gemma",
        "name": "google/gemma-3-4b-it",
        "torch_dtype": "float16",
        "low_memory": true,
        "requires_auth": false
      }
    }
  },
  "inference": {
    "batch_size": 32,
    "max_new_tokens": 512,
    "temperature": 0.01,
    "top_p": 0.9,
    "top_k": 50
  },
  "benchmarks": {
    "gsm8k": {
      "num_shots": 3,
      "split": "test",
      "dataset_fraction": 0.1
    }
  },
  "report_format": [
    "json",
    "md"
  ]
}